// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "./node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  worker
}

model Project {
  id          Int       @id @default(autoincrement())
  name        String
  description String
  startDate   DateTime
  deadline    DateTime
  hourLeft    Float
  projectType String
  status      Status?   @relation(fields: [statusId], references: [id])
  statusId    Int?
  customer    Customer? @relation(fields: [customerId], references: [id])
  customerId  Int?

  timeReports TimeReport[] // relation till tidrapporter
  tasks       ProjectTask[] // relation till todos

  projectRoles ProjectRole[] // koppling till users via roller
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Customer {
  id             Int     @id @default(autoincrement())
  name           String
  orderer        String // beställare
  contactName    String
  contactEmail   String
  contactPhone   String
  poNumber       String
  hourlyRate     Float
  totalCost      Float
  salesValue     Float
  partialInvoice Boolean // delfakturering

  projects Project[]
}

model Status {
  id       Int       @id @default(autoincrement())
  name     String // Ex: "Ej påbörjad", "Pausad", etc.
  projects Project[]
}

model ProjectRoleType {
  id           Int           @id @default(autoincrement())
  name         String // Ex: "Utvecklare", "Designer", etc.
  projectRoles ProjectRole[]
}

model ProjectRole {
  id        Int             @id @default(autoincrement())
  project   Project         @relation(fields: [projectId], references: [id])
  projectId Int
  user      User            @relation(fields: [userId], references: [id])
  userId    Int
  role      ProjectRoleType @relation(fields: [roleId], references: [id])
  roleId    Int

  hoursQuoted Float // Offererade timmar (per person/roll i projekt)
}

model User {
  id            Int           @id @default(autoincrement())
  name          String
  email         String        @unique
  username      String        @unique
  password      String
  role          String // admin / worker
  projectRoles  ProjectRole[]
  timeReports   TimeReport[]
  assignedTasks ProjectTask[] @relation("AssignedTasks")
}

model TimeReport {
  id          Int      @id @default(autoincrement())
  date        DateTime // Datumet då arbetet utfördes
  hoursWorked Float // Arbetade timmar
  part        String? // Del av projekt (t.ex. "Backend", "Test")
  description String? // Beskrivning
  notes       String? // Övrigt

  user   User @relation(fields: [userId], references: [id])
  userId Int

  project   Project @relation(fields: [projectId], references: [id])
  projectId Int

  createdAt DateTime @default(now())
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  BLOCKED
  DONE
}

model ProjectTask {
  id          Int        @id @default(autoincrement())
  title       String // Kort titel på vad som ska göras
  description String? // Beskrivning av uppgiften
  status      TaskStatus @default(PENDING)
  isCompleted Boolean    @default(false)
  dueDate     DateTime?

  project   Project @relation(fields: [projectId], references: [id])
  projectId Int

  assignedTo   User? @relation(fields: [assignedToId], references: [id], name: "AssignedTasks")
  assignedToId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
